---
import { galleryItems } from '../data/static/gallery';
const {limit=galleryItems.length}=Astro.props;
---
<div class="gallery-grid">{galleryItems.slice(0,limit).map((item,index)=><article class:list={['gallery-item',`gallery-item--${item.tone}`,{tall:index===1||index===4,wide:index===0||index===5}]}><span class="gallery-item__category">{item.category}</span><div><h3>{item.title}</h3><p>{item.caption}</p></div></article>)}</div>
<style>.gallery-grid{display:grid;gap:1rem;grid-auto-flow:dense;grid-template-columns:repeat(4,1fr)}.gallery-item{border-radius:1rem;display:flex;flex-direction:column;justify-content:space-between;min-height:210px;overflow:hidden;padding:1.15rem;position:relative}.gallery-item:after{background:linear-gradient(180deg,transparent 45%,rgba(74,51,38,.45));content:'';inset:0;position:absolute}.gallery-item>*{position:relative;z-index:1}.gallery-item--wheat{background:linear-gradient(135deg,#e9d39c,#b87b54)}.gallery-item--sage{background:linear-gradient(135deg,#c6cfad,#60745e)}.gallery-item--rose{background:linear-gradient(135deg,#e3b7a7,#a46a5b)}.gallery-item--cocoa{background:linear-gradient(135deg,#bd9779,#5b3e32)}.gallery-item--cream{background:linear-gradient(135deg,#fff5db,#d6b16c)}.gallery-item__category{background:rgba(255,255,255,.75);border-radius:99px;font-size:.65rem;font-weight:600;letter-spacing:.08em;padding:.3rem .55rem;text-transform:uppercase;width:max-content}.gallery-item h3{color:#fff;font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:500;margin:0}.gallery-item p{color:#fff;font-size:.72rem;margin:.15rem 0 0}.gallery-item.tall{grid-row:span 2;min-height:436px}.gallery-item.wide{grid-column:span 2}@media(max-width:650px){.gallery-grid{grid-template-columns:repeat(2,1fr)}.gallery-item{min-height:185px}.gallery-item.tall{min-height:385px}.gallery-item.wide{grid-column:span 2}}</style>
