---
const { number, title, text, items, href, tone='wheat' }=Astro.props;
---
<article class={`service-card service-card--${tone}`}><div class="service-card__top"><span>{number}</span><span class="hex">✦</span></div><h3>{title}</h3><p>{text}</p><ul>{items.map((item:string)=><li>{item}</li>)}</ul><a href={href}>Discover more <span>→</span></a></article>
<style>.service-card{border-radius:1.2rem;padding:2rem;position:relative}.service-card--wheat{background:#f6ead6}.service-card--sage{background:#e5e8d9}.service-card__top{color:var(--sage);display:flex;font-size:.78rem;font-weight:600;justify-content:space-between;letter-spacing:.1em}.hex{color:var(--honey);font-size:1rem}.service-card h3{font-family:'Playfair Display',serif;font-size:2rem;font-weight:500;letter-spacing:-.045em;margin:2rem 0 .65rem}.service-card p{color:var(--muted);margin:0}.service-card ul{display:flex;flex-wrap:wrap;gap:.45rem;list-style:none;margin:1.4rem 0;padding:0}.service-card li{background:rgba(255,255,255,.48);border-radius:99px;font-size:.74rem;padding:.3rem .6rem}.service-card a{font-size:.85rem;font-weight:600}.service-card a span{color:var(--honey);font-size:1.15rem;margin-left:.25rem}</style>
