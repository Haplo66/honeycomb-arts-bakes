<form class="contact-form" action="#" method="post"><div class="form-grid"><label>Full name<input required name="name" autocomplete="name" placeholder="Your name" /></label><label>Email address<input required type="email" name="email" autocomplete="email" placeholder="you@example.com" /></label><label>Phone <span>(optional)</span><input type="tel" name="phone" autocomplete="tel" placeholder="(000) 000-0000" /></label><label>I'm interested in<select name="service"><option>Bakery order</option><option>Sewing project</option><option>Custom request</option></select></label><label class="full">Preferred date <span>(optional)</span><input type="date" name="date" /></label><label class="full">Tell us a little about your idea<textarea required name="message" rows="5" placeholder="What can we help create?"></textarea></label></div><p class="form-note">This form is ready to connect to your preferred form service or GitHub-backed handler.</p><button class="button button--honey" type="submit">Send inquiry <span class="arrow">→</span></button></form>
<style>.form-grid{display:grid;gap:1rem;grid-template-columns:1fr 1fr}.contact-form label{color:var(--cocoa);display:flex;flex-direction:column;font-size:.78rem;font-weight:600;gap:.4rem}.contact-form label span{color:var(--muted);font-weight:400}.contact-form input,.contact-form select,.contact-form textarea{background:#fffdfa;border:1px solid var(--line);border-radius:.55rem;color:var(--cocoa);font-size:.92rem;outline-color:var(--honey);padding:.72rem .8rem}.contact-form .full{grid-column:span 2}.form-note{color:var(--muted);font-size:.78rem;margin:1rem 0}@media(max-width:550px){.form-grid{grid-template-columns:1fr}.contact-form .full{grid-column:auto}}</style>
