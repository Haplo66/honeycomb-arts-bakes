---
import MainLayout from '../layouts/MainLayout.astro';import ContactForm from '../components/ContactForm.astro';
---
<MainLayout title="Contact | Honeycomb Arts & Bakes" description="Start a bakery order, sewing project, or custom request with Honeycomb Arts & Bakes."><section class="page-hero"><div class="container"><span class="eyebrow">Let’s talk</span><h1 class="display">A good idea starts<br/>with a <em>hello.</em></h1><p>Tell us what you have in mind — a cake, a gift, a repair, or something completely your own.</p></div></section><section class="section"><div class="container contact-layout"><div><span class="eyebrow">Start here</span><h2 class="display">We’d love to<br/><em>hear from you.</em></h2><p>Share a few details and we’ll be in touch to talk through availability, ideas, and next steps.</p><div class="contact-details"><div><span>For orders &amp; projects</span><a href="mailto:hello@honeycombartsbakes.com">hello@honeycombartsbakes.com</a></div><div><span>Serving</span><p>Your local community<br/>and nearby celebrations</p></div></div></div><div class="form-card"><ContactForm/></div></div></section></MainLayout>
<style>.contact-layout{display:grid;gap:7rem;grid-template-columns:.8fr 1.2fr}.contact-layout>div>p{color:var(--muted);max-width:420px}.contact-details{border-top:1px solid var(--line);margin-top:2rem;padding-top:1.3rem}.contact-details>div{margin-bottom:1.1rem}.contact-details span{color:var(--sage);display:block;font-size:.7rem;font-weight:600;letter-spacing:.11em;text-transform:uppercase}.contact-details a,.contact-details p{font-size:.92rem;margin:.2rem 0}.form-card{background:#f6eddf;border-radius:1.1rem;padding:2rem}@media(max-width:800px){.contact-layout{gap:3rem;grid-template-columns:1fr}}</style>
