---
import MainLayout from '../../../layouts/MainLayout.astro';
import FormRenderer from '../../../components/forms/FormRenderer.astro';
import { getAllProducts } from '../../../data/products';
import { collections } from '../../../data/collections';
import { getProductOptions } from '../../../data/product-options';
import { sitePath } from '../../../utils/paths';
import { getProductPrimaryImage, getProductImages } from '../../../utils/images';
import type { Product } from '../../../types/product';

export async function getStaticPaths() {
  const products = getAllProducts();

  return products.map((product) => {
    let collectionSlug = '';

    const matched = collections.find(
      (collection) => collection.id === product.collectionId,
    );

    if (matched) {
      collectionSlug = matched.slug;
    }

    if (!collectionSlug) {
      collectionSlug = product.collectionId.replace(
        `${product.businessArea}-`,
        '',
      );
    }

    return {
      params: {
        businessArea: product.businessArea,
        collection: collectionSlug,
        slug: product.slug,
      },
      props: { product },
    };
  });
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

const imageTone = product.imageTone || 'cream';
const primaryImage = getProductPrimaryImage(product);
const imageStyle = primaryImage
  ? `background-image: url(${primaryImage});`
  : undefined;
const allImages = getProductImages(product);

const statusLabels: Record<string, string> = {
  available: 'Available',
  seasonal: 'Seasonal',
  'out-of-stock': 'Out of Stock',
  preorder: 'Preorder',
};

const statusLabel = statusLabels[product.status] || product.status;

const businessAreaTitle =
  product.businessArea === 'bakery'
    ? 'Bakery'
    : 'Sewing Studio';

const options = getProductOptions(product.id);

---

<MainLayout
  title={`${product.title} | RIPPLE Bakes & Makes`}
  description={product.shortDescription}
>
  <div class="product-detail">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={sitePath(product.businessArea)}>
          {businessAreaTitle}
        </a>

        <span class="separator" aria-hidden="true">/</span>

        <span class="current" aria-current="page">
          {product.title}
        </span>
      </nav>

      <div class="product-detail__grid">
        <div class="product-detail__media">
          <div
            class:list={[
              'product-detail__image',
              `image-panel--${imageTone}`,
            ]}
            style={imageStyle}
            role="img"
            aria-label={
              primaryImage
                ? product.title
                : `${product.title} visual treatment`
            }
          >
            <span
              class:list={[
                'status-badge',
                `status-badge--${product.status}`,
              ]}
            >
              {statusLabel}
            </span>
          </div>

          {allImages.length > 1 && (
            <div class="product-thumbnails">
              {allImages.map((url) => (
                <div
                  class:list={['product-thumbnail', `image-panel--${imageTone}`]}
                  style={`background-image: url(${url});`}
                  role="img"
                  aria-label={`${product.title} image`}
                ></div>
              ))}
            </div>
          )}
        </div>

        <div class="product-detail__content">
          <span class="eyebrow">{businessAreaTitle}</span>

          <h1 class="display product-detail__title">
            {product.title}
          </h1>

          {product.subtitle && (
            <p class="product-detail__subtitle">
              {product.subtitle}
            </p>
          )}

          {product.priceLabel && (
            <div class="product-detail__price">
              <span class="price-tag">
                {product.priceLabel}
              </span>
            </div>
          )}

          <div class="product-detail__description">
            <p class="short-desc">
              {product.shortDescription}
            </p>

            <p class="full-desc">
              {product.description}
            </p>
          </div>

          <div class="product-detail__meta">
            <div class="meta-item">
              <span class="meta-label">
                Availability Status
              </span>

              <span class="meta-value">
                {statusLabel}
              </span>
            </div>
          </div>

          {options.length > 0 && (
            <div class="product-detail__options">
              <h2 class="options-heading">Available Options</h2>
              {options.map((option) => (
                <div class="option-group">
                  <h3 class="option-name">{option.label}</h3>
                  {option.values && option.values.length > 0 ? (
                    <ul class="option-values">
                      {option.values.map((value) => (
                        <li class="option-value">{value}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="option-hint">Free text entry</p>
                  )}
                </div>
              ))}
            </div>
          )}

          <FormRenderer
            formId={product.formId}
            fallbackTitle={product.title}
            product={{
              collectionId: product.collectionId,
              productId: product.id,
              productTitle: product.title,
            }}
          />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .product-thumbnails {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .product-thumbnail {
    background-position: center;
    background-size: cover;
    border-radius: 0.6rem;
    height: 80px;
    width: 80px;
  }
  .product-detail__options {
    margin-top: 2rem;
  }
  .options-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: -.035em;
    margin: 0 0 1rem;
  }
  .option-group {
    margin-bottom: 1rem;
  }
  .option-name {
    font-size: .85rem;
    font-weight: 600;
    margin: 0 0 .35rem;
    text-transform: uppercase;
    letter-spacing: .03em;
  }
  .option-values {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .option-value {
    background: #f6eddf;
    border-radius: 2rem;
    font-size: .82rem;
    padding: .3rem .85rem;
  }
  .option-hint {
    color: var(--muted);
    font-size: .82rem;
    font-style: italic;
    margin: 0;
  }
</style>
