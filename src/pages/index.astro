---
import MainLayout from '../layouts/MainLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ServiceCard from '../components/ServiceCard.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ProductGrid from '../components/products/ProductGrid.astro';
import { testimonials } from '../data/static/testimonials';
import { getHomepageFeatured } from '../data/products';
import { sitePath } from '../utils/paths';

const featuredProducts = getHomepageFeatured();
---
<MainLayout title="RIPPLE Bakes & Makes | Handmade meets homemade" description="An artisan bakery and handmade studio creating thoughtful treats, gifts, and custom pieces.">
  <section class="home-hero"><div class="container hero-stack"><div class="hero-brand"><img class="hero-logo" src={sitePath('ripple-logo-transparent.png')} alt="RIPPLE Bakes & Makes"/><p class="hero-tagline">Handmade breads, treats &amp; creative pieces made with care.</p></div><div class="hero-visual" style={`background-image:url(${sitePath('images/home/hero/hero-01.jpg')})`} role="img" aria-label="Freshly baked filled pocket bread"></div><div class="hero-actions"><a class="button" href="bakery">Explore bakery <span class="arrow">→</span></a><a class="button button--light" href="sewing">Explore sewing <span class="arrow">→</span></a></div></div></section>
  <section class="section"><div class="container"><SectionTitle eyebrow="Two kinds of handmade" title="One warm, creative <em>home.</em>" text="From the oven to the sewing table, everything here begins with care for the little details."/><div class="services"><ServiceCard title="Artisan baking" text="Baked from scratch for everyday moments and the ones worth celebrating." items={['Breads','Cookies','Cakes','Seasonal treats','Custom orders']} href="bakery"/><ServiceCard title="Handmade arts" text="Sewn, stitched, and personalized pieces designed to feel truly yours." items={['Custom sewing','Gifts','Fabric creations','Home décor']} href="sewing" tone="sage"/></div></div></section>
  <section class="section section--paper"><div class="container story-preview"><div class="story-visual"><div class="image-panel image-panel--wheat"><span class="image-label">Made in small batches</span></div><div class="story-visual__accent">✦</div></div><div><span class="eyebrow">A little about us</span><h2 class="display">Two crafts,<br/>one <em>heart.</em></h2><p>RIPPLE Bakes &amp; Makes brings together the comfort of homemade baking and the joy of handmade pieces. It’s a small creative studio for treats, textiles, and thoughtful custom work.</p><p class="note">Every order is made with a personal touch — because the best things are never mass-produced.</p><a class="button button--light" href="about">Read our story <span class="arrow">→</span></a></div></div></section>
  <section class="section"><div class="container"><SectionTitle eyebrow="Handpicked favourites" title="A taste of what we <em>make.</em>" text="A few of the pieces our community loves most — from loaf to linen, each one tells a story."/><ProductGrid products={featuredProducts}/></div></section>
  <section class="section"><div class="container"><div class="section-row"><SectionTitle eyebrow="From our workspace" title="Fresh from the <em>kitchen &amp; studio.</em>" text="A living gallery of bakes, stitches, seasonal moments, and special requests."/><a class="text-link" href="gallery">View gallery →</a></div><GalleryGrid/></div></section>
  <section class="section why-section"><div class="container"><SectionTitle eyebrow="The RIPPLE way" title="Crafted to feel a little more <em>special.</em>"/><div class="why-grid"><article><span>01</span><h3>Handmade</h3><p>Careful hands, small batches, and details that make each piece its own.</p></article><article><span>02</span><h3>Fresh</h3><p>Thoughtfully made, close to home, and ready for your table or your gift bag.</p></article><article><span>03</span><h3>Personalized</h3><p>Custom touches and a collaborative approach for something that feels just right.</p></article></div></div></section>
  <section class="section section--paper"><div class="container"><SectionTitle eyebrow="Kind words" title="Made to be <em>shared.</em>" text="Notes from customers who have welcomed a little handmade warmth into their lives."/><div class="testimonial-grid">{testimonials.map(t=><TestimonialCard {...t}/>)}</div></div></section>
  <section class="cta-section"><div class="container"><div><span class="eyebrow">Have something in mind?</span><h2 class="display">Let’s make something<br/><em>lovely</em> together.</h2></div><a class="button button--honey" href="contact">Get in touch <span class="arrow">→</span></a></div></section>
</MainLayout>
<style>.home-hero{overflow:hidden;padding:5rem 0 4rem;position:relative;text-align:center}.home-hero:before{background-image:radial-gradient(rgba(214,165,75,.15) 1px,transparent 1px);background-size:18px 18px;content:'';height:180px;position:absolute;right:-40px;top:-30px;width:200px}.hero-stack{align-items:center;display:flex;flex-direction:column;gap:2.5rem}.hero-brand{align-items:center;display:flex;flex-direction:column;gap:.5rem}.hero-logo{height:auto;max-width:600px;transform:translateX(-20px);width:100%}.hero-tagline{color:var(--cocoa);font-family:'Dancing Script',cursive;font-size:2rem;font-weight:600;line-height:1.25;margin:0;max-width:600px}.hero-visual{background-size:cover;background-position:center 30%;border-radius:1.2rem;box-shadow:var(--shadow);height:420px;max-width:820px;position:relative;width:100%}.hero-visual:before{background:linear-gradient(180deg,transparent 35%,rgba(74,51,38,.5)),radial-gradient(circle at 50% 0,transparent 40%,rgba(92,65,50,.25));content:'';inset:0;position:absolute;border-radius:inherit}.hero-actions{display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center}@media(max-width:700px){.home-hero{padding:2.8rem 0}.hero-logo{max-width:350px;transform:none}.hero-stack{gap:2rem}.hero-visual{height:280px}.hero-tagline{font-size:1.55rem}}.services{display:grid;gap:1.25rem;grid-template-columns:1fr 1fr}.story-preview{align-items:center;display:grid;gap:7rem;grid-template-columns:1fr 1fr}.story-preview p:not(.note){color:var(--muted);max-width:480px}.story-visual{height:420px;position:relative}.story-visual .image-panel{height:100%;width:86%}.story-visual__accent{align-items:center;background:var(--sage);border-radius:50%;bottom:-1.5rem;color:white;display:flex;font-size:1.6rem;height:98px;justify-content:center;position:absolute;right:0;width:98px}.section-row{align-items:start;display:flex;justify-content:space-between}.text-link{font-size:.85rem;font-weight:600;margin-top:1.7rem;white-space:nowrap}.why-section{background:#f3eadc}.why-grid{display:grid;gap:1rem;grid-template-columns:repeat(3,1fr)}.why-grid article{border-top:1px solid #cbbda6;padding-top:1.1rem}.why-grid span{color:var(--sage);font-size:.72rem;font-weight:600;letter-spacing:.1em}.why-grid h3{font-family:'Playfair Display',serif;font-size:1.65rem;font-weight:500;margin:.65rem 0}.why-grid p{color:var(--muted);font-size:.9rem;margin:0}.testimonial-grid{display:grid;gap:1rem;grid-template-columns:repeat(3,1fr)}.cta-section{background:var(--cocoa);color:#fff7ea;padding:5rem 0}.cta-section .container{align-items:end;display:flex;justify-content:space-between}.cta-section .eyebrow{color:var(--gold)}.cta-section .display{margin-bottom:0}.cta-section .display em{color:var(--gold)}@media(max-width:780px){.home-hero{padding-top:4.5rem}.hero-grid,.story-preview{gap:3rem;grid-template-columns:1fr}.hero-art{height:420px;max-width:540px}.story-preview{gap:3.5rem}.story-visual{height:350px}.testimonial-grid{grid-template-columns:1fr}.cta-section .container{align-items:start;gap:2rem;flex-direction:column}}@media(max-width:550px){.services,.why-grid{grid-template-columns:1fr}.section-row{display:block}.text-link{display:inline-block;margin-top:-1.2rem;margin-bottom:1.8rem}.hero-art__card{left:1rem}.cta-section{padding:4rem 0}}</style>
