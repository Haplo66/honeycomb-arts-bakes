---
import MainLayout from '../layouts/MainLayout.astro';import GalleryGrid from '../components/GalleryGrid.astro';
---
<MainLayout title="Gallery | Honeycomb Arts & Bakes" description="A gallery of artisan baking, sewing, seasonal work, and custom orders."><section class="page-hero"><div class="container"><span class="eyebrow">The gallery</span><h1 class="display">Little moments, <em>beautifully made.</em></h1><p>A growing collection of work from the kitchen and the studio. Photography slots are ready for the real thing.</p></div></section><section class="section"><div class="container"><div class="filters" aria-label="Gallery categories"><button class="active">All work</button><button>Baking</button><button>Sewing</button><button>Seasonal</button><button>Custom orders</button></div><GalleryGrid/></div></section></MainLayout>
<style>.filters{display:flex;flex-wrap:wrap;gap:.55rem;margin-bottom:2rem}.filters button{background:transparent;border:1px solid var(--line);border-radius:99px;color:var(--muted);cursor:pointer;font-size:.78rem;padding:.5rem .85rem}.filters button.active,.filters button:hover{background:var(--cocoa);border-color:var(--cocoa);color:#fff}</style>
